{
  "tasks": {
    "dev": "deno run --watch main.ts",
    "test": "deno test -A --no-check",
    "test:cov": "deno test -A --no-check --coverage=cov_profile",
    "coverage": "deno coverage cov_profile",
    "coverage:html": "deno coverage cov_profile --html"
  },
  "imports": {
    "@std/dotenv": "jsr:@std/dotenv@^0.225.6",
    "@zarco/isness": "jsr:@zarco/isness@^0.1.18",
    "express": "npm:express@^5.2.1",
    "mongodb": "npm:mongodb@6.1.0",
    "@db/mongo": "jsr:@db/mongo@^0.34.0",
    "@std/assert": "jsr:@std/assert@1",
    "mongoose": "npm:mongoose@^8.9.5",
    "morgan": "npm:morgan@^1.10.1",
    "request-check": "npm:request-check@^1.6.2",
    "responser": "npm:responser@^2.5.6",
    "supertest": "npm:supertest@^7.2.2",
    "throwlhos": "npm:throwlhos@^1.1.0",
    "bcryptjs": "npm:bcryptjs@^2.4.3",
    "jsonwebtoken": "npm:jsonwebtoken@^9.0.2",
    "swagger-ui-express": "npm:swagger-ui-express@^5.0.1"
  }
}
